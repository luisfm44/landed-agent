# =============================================================================
# Landed Agent — Environment profile
# =============================================================================
# Copy to .env and activate ONE profile block.
#
# GCP  → Gemini via ADK (default for Cloud Run / Vertex)
# Local → Ollama via LiteLLM (offline dev on your Mac)
# =============================================================================


# --- ACTIVE: GCP profile -----------------------------------------------------
LLM_RUNTIME=gcp
ORCHESTRATOR_MODEL=gemini-2.5-flash-lite
FAST_AGENT_MODEL=gemini-2.5-flash-lite
REASONING_AGENT_MODEL=gemini-2.5-flash-lite
# GOOGLE_API_KEY=your-gemini-api-key
# Or use Application Default Credentials in Google Cloud.


# --- INACTIVE: Local profile (Ollama) ----------------------------------------
# Comment the GCP block above and uncomment this block to run fully local.
#
# LLM_RUNTIME=local
# ORCHESTRATOR_MODEL=llama3.1
# FAST_AGENT_MODEL=llama3.1
# REASONING_AGENT_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_GROUNDING_MODEL=llama3.1
#
# Requires:
#   ollama serve
#   ollama pull llama3.1
#   ollama pull nomic-embed-text


# --- Shared services ---------------------------------------------------------
LANDED_API_BASE_URL=http://localhost:3001

# Optional tuning
# LANDED_API_TIMEOUT_SECONDS=60
# LANDED_API_MAX_RETRIES=2
# MAX_TOOL_CALLS_PER_REQUEST=12
